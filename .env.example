# SMTP Server Configuration
SMTP_HOST=0.0.0.0
SMTP_PORT=2525

# Web Server Configuration
WEB_PORT=8000

# Domain for email addresses
DOMAIN=localhost

# Email retention (hours)
MAX_EMAIL_AGE_HOURS=24

# Forwarding verification expiry (hours)
FORWARD_VERIFICATION_EXPIRY_HOURS=24

# SMTP credentials for sending forwarded emails (optional)
# FORWARD_SMTP_HOST=smtp.gmail.com
# FORWARD_SMTP_PORT=587
# FORWARD_SMTP_USER=your-email@gmail.com
# FORWARD_SMTP_PASS=your-app-password